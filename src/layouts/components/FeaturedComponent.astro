---
interface Props {
  item: {
    name: string;
    type?: string;
    description: string;
    technologies: string[] | string;
    tools?: string[] | string;
    deploy?: string;
    source?: string;
    thumbnail?: string;
  };
  index: number;
}

const { item, index } = Astro.props;

const techs = Array.isArray(item.technologies)
  ? item.technologies
  : item.technologies.split(",").map((t) => t.trim());

const tools = item.tools
  ? Array.isArray(item.tools)
    ? item.tools
    : item.tools.split(",").map((t) => t.trim())
  : [];

const iconSlug: Record<string, string> = {
  javascript: "javascript",
  typescript: "typescript",
  nodejs: "nodedotjs",
  expressjs: "express",
  python: "python",
  php: "php",
  laravel: "laravel",
  wordpress: "wordpress",
  postgresql: "postgresql",
  prisma: "prisma",
  mongoose: "mongoose",
  vite: "vite",
  websockets: "socketdotio",
  "socket.io": "socketdotio",
  swagger: "swagger",
  "google api": "google",
};

const modalId = `fi-modal-${index}`;
---

<!-- Row -->
<button class="fi" aria-haspopup="dialog" data-fi-open={modalId}>
  <div class="fi-main">
    <div class="fi-header">
      <span class="fi-name">{item.name}</span>
      <span class="fi-sep">/</span>
      {item.type && <span class="fi-type">{item.type}</span>}
      <span class="fi-sep">/</span>
      <span class="fi-desc">{item.description}</span>
    </div>
  </div>

  <div class="fi-icons" aria-label="Technologies">
    {
      techs.length > 3 && (
        <div class="fi-icon-wrap fi-icon-more">+{techs.length - 3}</div>
      )
    }
    {
      techs
        .slice(0, 3)
        .reverse()
        .map((tech) => {
          const slug = iconSlug[tech.toLowerCase()];
          return slug ? (
            <div class="fi-icon-wrap" title={tech}>
              <img
                src={`https://cdn.simpleicons.org/${slug}`}
                alt={tech}
                width="11"
                height="11"
                class="fi-icon"
                onerror="this.style.display='none'"
              />
            </div>
          ) : (
            <div class="fi-icon-wrap fi-icon-fallback" title={tech}>
              {tech.charAt(0)}
            </div>
          );
        })
    }
  </div>
</button>

<!-- Modal -->
<dialog class="fi-modal" id={modalId} aria-label={item.name}>
  <div class="fi-modal-inner">
    <div class="fi-modal-topbar">
      <div class="fi-modal-title-row">
        <div class="fi-modal-thumb" aria-hidden="true">
          {
            item.thumbnail ? (
              <img
                src={item.thumbnail}
                alt=""
                style="width:100%;height:100%;object-fit:cover;border-radius:2px;"
              />
            ) : (
              <span class="fi-modal-letter">
                {item.name.charAt(0).toUpperCase()}
              </span>
            )
          }
        </div>
        <div>
          <h2 class="fi-modal-name">{item.name}</h2>
          {item.type && <span class="fi-modal-type">{item.type}</span>}
        </div>
      </div>
      <button class="fi-modal-close" aria-label="Close" data-fi-close>
        <svg viewBox="0 0 14 14" aria-hidden="true">
          <path
            d="M11 3L3 11M3 3l8 8"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>

    {
      (item.source || (item.deploy && item.deploy.trim() !== "")) && (
        <div class="fi-modal-links">
          {item.source && (
            <a
              href={item.source}
              target="_blank"
              rel="noopener noreferrer"
              class="fi-modal-link"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.73.5.5 5.87.5 12.35c0 5.18 3.44 9.58 8.2 11.13.6.12.82-.27.82-.58v-2.17c-3.34.75-4.04-1.65-4.04-1.65-.55-1.42-1.35-1.8-1.35-1.8-1.1-.78.08-.77.08-.77 1.22.09 1.86 1.3 1.86 1.3 1.08 1.9 2.83 1.35 3.52 1.03.11-.81.42-1.35.76-1.66-2.66-.31-5.46-1.37-5.46-6.08 0-1.34.46-2.43 1.22-3.29-.12-.31-.53-1.57.12-3.27 0 0 1-.33 3.3 1.26a11.2 11.2 0 0 1 6 0c2.3-1.6 3.3-1.26 3.3-1.26.65 1.7.24 2.96.12 3.27.76.86 1.22 1.95 1.22 3.29 0 4.72-2.8 5.76-5.47 6.07.43.38.81 1.12.81 2.27v3.36c0 .32.22.7.83.58 4.76-1.55 8.19-5.95 8.19-11.13C23.5 5.87 18.27.5 12 .5z" />
              </svg>
              Source
            </a>
          )}
          {item.deploy && item.deploy.trim() !== "" && (
            <a
              href={item.deploy}
              target="_blank"
              rel="noopener noreferrer"
              class="fi-modal-link accent"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3z" />
                <path d="M5 5h6V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6h-2v6H5V5z" />
              </svg>
              Live demo
            </a>
          )}
        </div>
      )
    }

    <p class="fi-modal-desc">{item.description}</p>

    <div class="fi-modal-tags">
      {techs.map((t) => <span>{t}</span>)}
      {tools.map((t) => <span class="tool">{t}</span>)}
    </div>
  </div>
</dialog>

<style>
  .fi {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.52rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    text-align: left;
    color: inherit;
    font: inherit;
    width: 100%;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  :global(body.light) .fi {
    border-bottom-color: rgba(0, 0, 0, 0.07);
  }
  .fi:last-of-type {
    border-bottom: none;
  }
  .fi:hover {
    opacity: 0.6;
  }

  .fi-main {
    min-width: 0;
    flex: 1;
  }

  .fi {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.52rem 0;
    border-bottom: 1px solid var(--border);
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    text-align: left;
    color: inherit;
    font: inherit;
    width: 100%;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .fi:last-of-type {
    border-bottom: none;
  }
  .fi:hover {
    opacity: 0.6;
  }

  .fi-main {
    min-width: 0;
    flex: 1;
  }

  .fi-header {
    display: flex;
    align-items: baseline;
    gap: 0.38rem;
    min-width: 0;
    overflow: hidden;
  }

  .fi-name {
    font-size: 0.82rem;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .fi-sep {
    font-size: 0.75rem;
    opacity: 0.2;
    flex-shrink: 0;
  }
  .fi-type {
    font-size: 0.75rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .fi-desc {
    font-size: 0.75rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .fi-icons {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    flex-direction: row-reverse;
    justify-content: flex-end;
  }

  .fi-icon-wrap {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid var(--icon-border);
    background: var(--icon-bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-left: -6px;
    flex-shrink: 0;
  }

  .fi-icon-more {
    font-size: 0.48rem;
    font-weight: 600;
    background: var(--icon-more-bg);
    color: inherit;
    font-family: inherit;
    letter-spacing: -0.02em;
    opacity: 0.7;
  }

  .fi-icon {
    width: 11px;
    height: 11px;
    object-fit: contain;
  }

  .fi-icon-fallback {
    font-size: 0.48rem;
    font-weight: 700;
    opacity: 0.5;
    font-family: inherit;
  }

  .fi-icons .fi-icon-wrap:last-child {
    margin-left: 0;
  }

  .fi-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    max-width: 520px;
    width: calc(100% - 1.5rem);
    max-height: min(520px, calc(100vh - 1.5rem));
    border-radius: 4px;
    border: 1px solid var(--border-h);
    background: var(--modal-bg);
    color: inherit;
    font-family: inherit;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    outline: none;
  }

  .fi-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(3px);
  }
  .fi-modal[open] {
    animation: fiModalIn 0.18s ease;
  }

  @keyframes fiModalIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .fi-modal-inner {
    padding: 1.4rem 1.5rem 1.5rem;
    overflow-y: auto;
    max-height: min(520px, calc(100vh - 1.5rem));
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .fi-modal-topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .fi-modal-title-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .fi-modal-thumb {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: 3px;
    background: var(--surface-h);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .fi-modal-letter {
    font-size: 1rem;
    font-weight: 700;
    opacity: 0.35;
    font-family: inherit;
  }

  .fi-modal-name {
    margin: 0 0 0.18rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .fi-modal-type {
    font-size: 0.6rem;
    font-family: inherit;
    padding: 0.1rem 0.38rem;
    border-radius: 2px;
    background: rgba(124, 110, 247, 0.1);
    color: #7c6ef7;
    border: 1px solid rgba(124, 110, 247, 0.22);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .fi-modal-close {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    background: var(--surface-h);
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px;
    margin-top: 1px;
    transition: background 0.13s;
  }
  .fi-modal-close:hover {
    background: var(--border);
  }
  .fi-modal-close svg {
    width: 100%;
    height: 100%;
  }

  .fi-modal-links {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .fi-modal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    color: inherit;
    opacity: 0.5;
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 0.24rem 0.6rem;
    border-radius: 2px;
    transition:
      opacity 0.13s,
      border-color 0.13s;
    font-family: inherit;
  }
  .fi-modal-link:hover {
    opacity: 1;
    border-color: var(--border-h);
  }
  .fi-modal-link.accent {
    opacity: 0.85;
    color: #7c6ef7;
    border-color: rgba(124, 110, 247, 0.22);
    background: rgba(124, 110, 247, 0.08);
  }
  .fi-modal-link svg {
    width: 12px;
    height: 12px;
  }

  .fi-modal-desc {
    margin: 0;
    font-size: 0.82rem;
    opacity: 0.6;
    line-height: 1.65;
  }

  .fi-modal-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .fi-modal-tags span {
    font-size: 0.67rem;
    font-family: inherit;
    padding: 0.12rem 0.4rem;
    border-radius: 2px;
    background: var(--surface-h);
    opacity: 0.75;
    border: 1px solid var(--border);
  }
  .fi-modal-tags span.tool {
    opacity: 0.35;
  }
</style>

<script>
  document.querySelectorAll("[data-fi-open]").forEach((btn) => {
    const id = (btn as HTMLElement).dataset.fiOpen!;
    const modal = document.getElementById(id) as HTMLDialogElement | null;
    if (!modal) return;
    btn.addEventListener("click", () => modal.showModal());
    modal
      .querySelector("[data-fi-close]")
      ?.addEventListener("click", () => modal.close());
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.close();
    });
  });
</script>
