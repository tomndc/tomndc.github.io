---
interface Props {
  item: {
    name: string;
    description: string;
    technologies: string[] | string;
    source?: string;
    deploy?: string;
    thumbnail?: string;
  };
}

const { item } = Astro.props;

const tags = Array.isArray(item.technologies)
  ? item.technologies
  : item.technologies.split(",");

const initial = item.name.charAt(0).toUpperCase();
---

<article class="row">
  <div class="thumb">
    {
      item.thumbnail ? (
        <img src={item.thumbnail} alt={item.name} />
      ) : (
        <span class="thumb-letter">{initial}</span>
      )
    }
  </div>

  <div class="content">
    <div class="header">
      <h3>{item.name}</h3>

      <div class="actions">
        {
          item.source && (
            <a
              href={item.source}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Source code"
              title="Source code"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 .5C5.73.5.5 5.87.5 12.35c0 5.18 3.44 9.58 8.2 11.13.6.12.82-.27.82-.58v-2.17c-3.34.75-4.04-1.65-4.04-1.65-.55-1.42-1.35-1.8-1.35-1.8-1.1-.78.08-.77.08-.77 1.22.09 1.86 1.3 1.86 1.3 1.08 1.9 2.83 1.35 3.52 1.03.11-.81.42-1.35.76-1.66-2.66-.31-5.46-1.37-5.46-6.08 0-1.34.46-2.43 1.22-3.29-.12-.31-.53-1.57.12-3.27 0 0 1-.33 3.3 1.26a11.2 11.2 0 0 1 6 0c2.3-1.6 3.3-1.26 3.3-1.26.65 1.7.24 2.96.12 3.27.76.86 1.22 1.95 1.22 3.29 0 4.72-2.8 5.76-5.47 6.07.43.38.81 1.12.81 2.27v3.36c0 .32.22.7.83.58 4.76-1.55 8.19-5.95 8.19-11.13C23.5 5.87 18.27.5 12 .5z" />
              </svg>
            </a>
          )
        }
        {
          item.deploy && item.deploy.trim() !== "" && (
            <a
              href={item.deploy}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Live demo"
              title="Live demo"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3z" />
                <path d="M5 5h6V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6h-2v6H5V5z" />
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <p>{item.description}</p>

    <div class="tags">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>

<style>
  /* layout principal */
  .row {
    display: grid;
    grid-template-columns: 44px 1fr;
    align-items: start;
    gap: 0.75rem;
    padding: 0.5rem 0;

    /* lift sutil solo al elemento */
    transition: transform 0.25s ease;
  }
  .row:hover {
    transform: translateY(-2px);
  }

  /* thumbnail */
  .thumb {
    width: 34px;
    height: 34px;
    border-radius: 5px;
    background: color-mix(in srgb, currentColor 12%, transparent);
    overflow: hidden;

    display: flex;
    align-items: center;
    justify-content: center;

    transition:
      border-color 0.25s ease,
      transform 0.25s ease;
    border: 2px solid transparent; /* borde inicial invisible */
  }
  .row:hover .thumb {
    border-color: rgba(255, 255, 255, 0.25); /* solo cambia el borde */
    transform: scale(1.03);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-letter {
    font-size: 1.1rem;
    font-weight: 600;
    opacity: 0.8;
    text-transform: uppercase;
  }

  /* contenido */
  .content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* header */
  .header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.75rem;
  }

  .content h3 {
    margin: 0;
    font-size: 1em;
    font-weight: 600;
  }

  .content p {
    margin: 0.15rem 0 0.5rem;
    font-size: 0.85em;
    opacity: 0.75;
    line-height: 1.4;
  }

  /* tags */
  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 0.75em;
  }
  .tags span {
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: color-mix(in srgb, currentColor 10%, transparent);
    opacity: 0.85;
  }

  /* actions */
  .actions {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.1rem;
    font-size: 0.8em;
    opacity: 0.6;
    transition: opacity 0.25s ease;
  }
  .row:hover .actions {
    opacity: 1;
  }

  .actions a {
    display: inline-flex;
    width: 16px;
    height: 16px;
    color: inherit;
  }
  .actions a:hover {
    opacity: 1;
  }
  .actions svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
    /* sin cambios al hover, independientes */
  }
</style>
