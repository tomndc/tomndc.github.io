---
interface Props {
  name: string;
  subtitle: string;
  avatar: string;
}

const { name, subtitle, avatar } = Astro.props;
---

<div class="profile">
  <div class="avatar-wrap">
    <img src={avatar} alt={name} class="avatar" />
    <span class="bubble">Say hi!</span>
  </div>

  <div class="info">
    <h2>{name}</h2>
    <p>{subtitle}</p>
  </div>
</div>

<style>
  .profile {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: inherit;
    color: inherit;
    width: fit-content;
  }

  .avatar-wrap {
    position: relative;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 5px;
    object-fit: cover;
    display: block;
    border: 1px solid inherit;
    transform: scaleX(-1);
    transition: border-color 0.15s;
  }

  :global(body.light) .avatar {
    border-color: rgba(0, 0, 0, 0.1);
  }

  .avatar-wrap:hover .avatar {
    border-color: rgba(255, 255, 255, 0.22);
  }

  :global(body.light) .avatar-wrap:hover .avatar {
    border-color: rgba(0, 0, 0, 0.22);
  }

  .bubble {
    position: absolute;
    right: calc(100% + 8px);
    top: 50%;
    transform: translateY(-50%) translateX(4px);

    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: inherit;

    font-size: 11px;
    font-family: inherit;
    padding: 3px 8px;
    border-radius: 3px;

    white-space: nowrap;
    opacity: 0;
    pointer-events: none;

    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  :global(body.light) .bubble {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.1);
  }

  .avatar-wrap:hover .bubble {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .info h2 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .info p {
    margin: 2px 0 0;
    font-size: 13px;
    opacity: 0.45;
  }
</style>
