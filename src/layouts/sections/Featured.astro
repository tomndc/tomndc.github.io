---
import FeaturedComponent from "../components/FeaturedComponent.astro";
import projects from "../../lib/data/projects-data.json";

const featured = (projects as any[]).filter((p) => p.featured === true);
---

{
  featured.length > 0 && (
    <section class="fs" aria-label="Featured projects">
      <p class="fs-label">Featured work ({featured.length})</p>
      <div class="fs-list">
        {featured.map((project) => (
          <FeaturedComponent item={project} />
        ))}
      </div>
    </section>
  )
}

<style>
  .fs {
    margin-top: 1rem;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.07));
    border-radius: 3px;
    padding: 0.75rem 0.9rem;
    background: var(--surface, rgba(243, 0, 0, 0.02));
    color: inherit;
    font-family: inherit;
  }

  .fs-label {
    font-size: 0.68rem;
    font-family: inherit;
    opacity: 0.3;
    margin: 0 0 0.6rem;
    letter-spacing: 0.01em;
  }

  .fs-list {
    display: flex;
    flex-direction: column;
  }
</style>
