---
import ProjectCard from "../components/ProjectComponent.astro";
import projects from "../../lib/data/projects-data.json";

const allTechnologies: string[] = [
  ...new Set(
    projects.flatMap((p: any) =>
      Array.isArray(p.technologies)
        ? p.technologies
        : p.technologies.split(",").map((t: string) => t.trim()),
    ),
  ),
].sort();

const allTypes: string[] = [
  ...new Set(projects.map((p: any) => p.type).filter(Boolean)),
].sort() as string[];
---

<section class="ps" aria-label="Projects">
  <div class="ps-head" id="ps-head">
    <div class="search-bar" role="search" aria-label="Search projects">
      <label for="ps-input" class="sr-only">Search by type or technology</label>

      <div class="input-shell" id="input-shell">
        <svg class="ico-search" viewBox="0 0 18 18" aria-hidden="true">
          <circle
            cx="7.5"
            cy="7.5"
            r="5"
            stroke="currentColor"
            stroke-width="1.35"
            fill="none"></circle>
          <path
            d="M11.5 11.5L16 16"
            stroke="currentColor"
            stroke-width="1.35"
            stroke-linecap="round"></path>
        </svg>

        <div
          class="chips-row"
          id="chips-row"
          role="group"
          aria-label="Active filters"
        >
        </div>

        <input
          id="ps-input"
          type="text"
          placeholder="Search by type or tech :)"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-autocomplete="list"
          aria-controls="ps-sugs"
          aria-haspopup="listbox"
          aria-expanded="false"
        />

        <button
          id="ps-clear"
          class="ico-btn"
          aria-label="Clear all"
          type="button"
          hidden
        >
          <svg viewBox="0 0 14 14" aria-hidden="true">
            <path
              d="M11 3L3 11M3 3l8 8"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>

      <div class="hint" id="ps-hint" aria-hidden="true">
        <span class="hint-label">e.g.</span>
        <span class="hint-pill type">Fullstack</span>
        <span class="hint-sep">·</span>
        <span class="hint-pill tech">Python</span>
        <span class="hint-sep">·</span>
        <span class="hint-pill tech">Testing</span>
        <span class="hint-sep">·</span>
        <span class="hint-pill type">Cloud</span>
      </div>

      <ul
        id="ps-sugs"
        class="sugs"
        role="listbox"
        aria-label="Suggestions"
        hidden
      >
      </ul>
    </div>
  </div>

  <p class="meta" id="ps-meta" aria-live="polite" aria-atomic="true"></p>

  <div class="grid-shell" id="grid-shell" hidden>
    <div id="ps-grid" class="grid" role="feed" aria-label="Projects">
      {
        projects.map((project: any, i: number) => (
          <ProjectCard item={project} index={i} />
        ))
      }
    </div>
  </div>

  <div id="ps-idle" class="idle" role="status" aria-live="polite">
    <p>Search by technology or type to discover projects.</p>
  </div>
</section>

<style>
  .ps {
    --accent: #7c6ef7;
    --accent-dim: rgba(124, 110, 247, 0.1);
    --accent-border: rgba(124, 110, 247, 0.25);
    --lime: #a3e635;
    --lime-dim: rgba(163, 230, 53, 0.1);
    --lime-border: rgba(163, 230, 53, 0.25);
    --font-mono: "IBM Plex Mono", "Fira Mono", monospace;

    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding-top: 2rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .search-bar {
    position: relative;
  }

  .input-shell {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.32rem 0.6rem;
    min-height: 36px;
    cursor: text;
    transition:
      border-color 0.16s,
      box-shadow 0.16s,
      background 0.16s;
  }

  .input-shell:focus-within {
    border-color: rgba(124, 110, 247, 0.42);
    background: rgba(255, 255, 255, 0.045);
    box-shadow: 0 0 0 3px rgba(124, 110, 247, 0.07);
  }

  .ico-search {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    opacity: 0.28;
    color: currentColor;
    transition: opacity 0.16s;
    align-self: center;
  }

  .input-shell:focus-within .ico-search {
    opacity: 0.55;
  }

  .chips-row {
    display: contents;
  }

  #ps-input {
    flex: 1;
    min-width: 140px;
    background: transparent;
    border: none;
    outline: none;
    font-size: 0.815rem;
    color: inherit;
    font-family: inherit;
    caret-color: var(--accent);
    padding: 0;
    align-self: center;
    line-height: 1;
  }

  #ps-input::placeholder {
    opacity: 0.28;
  }

  .ico-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.07);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: inherit;
    padding: 3.5px;
    align-self: center;
    transition:
      background 0.13s,
      opacity 0.13s;
    opacity: 1;
  }

  .ico-btn[hidden] {
    display: flex !important;
    opacity: 0;
    pointer-events: none;
  }

  .ico-btn:hover {
    background: rgba(255, 255, 255, 0.14);
  }
  .ico-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .ico-btn svg {
    width: 100%;
    height: 100%;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.71rem;
    font-family: var(--font-mono);
    padding: 0.22rem 0.22rem 0.22rem 0.62rem;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.8);
    animation: chipIn 0.13s ease both;
    cursor: default;
    line-height: 1;
  }

  .chip-label {
    font-size: 0.71rem;
  }

  @keyframes chipIn {
    from {
      opacity: 0;
      transform: scale(0.82);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .chip-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border-radius: 50%;
    cursor: pointer;
    padding: 4px;
    transition: filter 0.12s;
    user-select: none;
  }

  .chip.tech .chip-x {
    background-color: #a3e635 !important;
    color: #0a0a0a !important;
  }
  .chip.type .chip-x {
    background-color: #7c6ef7 !important;
    color: #fff !important;
  }
  .chip-x:hover {
    filter: brightness(0.75);
  }
  .chip-x:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  .chip-x svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hint {
    display: flex;
    align-items: center;
    gap: 0.32rem;
    flex-wrap: wrap;
    padding: 0.38rem 0.05rem 0;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    opacity: 0.3;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .hint-label {
    opacity: 0.6;
  }
  .hint-sep {
    opacity: 0.35;
  }

  .hint-pill {
    padding: 0.07rem 0.36rem;
    border-radius: 999px;
    font-size: 0.6rem;
    letter-spacing: 0.03em;
  }

  .hint-pill.tech {
    background: var(--lime-dim);
    color: var(--lime);
    border: 1px solid var(--lime-border);
  }

  .hint-pill.type {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--accent-border);
  }

  .sugs {
    position: absolute;
    top: calc(100% + 5px);
    left: 0;
    right: 0;
    display: block;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: #0e0e11;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.55);
    z-index: 200;
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 0.13s ease,
      transform 0.13s ease;
    pointer-events: none;
  }

  .sugs:not([hidden]) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .sug-item {
    display: flex;
    align-items: center;
    padding: 0.32rem 0.5rem;
    border-radius: 2px;
    cursor: pointer;
    color: inherit;
    border: 1px solid transparent;
    transition:
      background 0.09s,
      border-color 0.09s;
    outline: none;
    user-select: none;
    background: none;
  }

  .sug-item:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }
  .sug-item.is-active {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .sug-pill {
    font-size: 0.71rem;
    font-family: var(--font-mono);
    padding: 0.15rem 0.52rem;
    border-radius: 999px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .sug-item.tech-item .sug-pill {
    background: var(--lime-dim);
    color: var(--lime);
    border: 1px solid var(--lime-border);
  }

  .sug-item.type-item .sug-pill {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--accent-border);
  }

  .meta {
    margin: 0;
    font-size: 0.68rem;
    font-family: var(--font-mono);
    opacity: 0.3;
    min-height: 1em;
  }

  .grid-shell {
    max-height: 260px;
    overflow-y: auto;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 0.35rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
  }

  .grid-shell::-webkit-scrollbar {
    width: 3px;
  }
  .grid-shell::-webkit-scrollbar-track {
    background: transparent;
  }
  .grid-shell::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5rem;
  }

  .idle {
    display: none;
  }
</style>
<script define:vars={{ projects, allTechnologies, allTypes }}>
  window.__PS_DATA__ = { projects, allTechnologies, allTypes };
</script>
<script src="../../scripts/search.js"></script>
