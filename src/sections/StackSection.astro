---
import stackData from "../lib/data/stack-data.json";

const { stack, learning } = stackData as any;
const all = [{ category: "learning", items: learning }, ...stack];
---

<section class="stack-section" id="section-stack">
  <div class="dir-scroll">
    {
      all.map((group: any) => (
        <div class="sg">
          <div class="sg-label">
            <svg
              viewBox="0 0 12 12"
              fill="none"
              width="9"
              height="9"
              class="sg-icon-folder"
            >
              <path
                d="M1 3h4l1 1.5h5V10H1z"
                stroke="currentColor"
                stroke-width="1"
                stroke-linejoin="round"
              />
            </svg>
            <span>{group.category}</span>
          </div>
          <div class="sg-items">
            {group.items.map((item: any) => (
              <div class="sg-item">
                <span class="sg-icon">
                  {item.icon ? (
                    <img
                      src={`https://cdn.simpleicons.org/${item.icon}`}
                      alt=""
                      width="11"
                      height="11"
                      onerror="this.style.display='none'"
                    />
                  ) : (
                    <span class="sg-dot" />
                  )}
                </span>
                <span class="sg-name">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .stack-section {
    flex: 1;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-bottom: 0.55rem;
  }

  :global(body[data-bio-state="searching"]) #section-stack,
  :global(body[data-bio-state="many-tags"]) #section-stack,
  :global(body[data-bio-state="featured"]) #section-stack,
  :global(body[data-bio-state="work-only"]) #section-stack,
  :global(body.detail) #section-stack,
  :global(body.feat-expanded) #section-stack {
    display: none;
  }

  .dir-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--surface);
    margin-top: 0.5rem;
    padding: 0.7rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .dir-scroll::-webkit-scrollbar {
    width: 3px;
  }
  .dir-scroll::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }

  .sg {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.6rem;
    align-items: start;
  }

  .sg-label {
    display: flex;
    align-items: center;
    gap: 0.28rem;
    padding-top: 0.08rem;
  }

  .sg-icon-folder {
    opacity: 0.3;
    flex-shrink: 0;
  }

  .sg-label span {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    font-weight: 400;
    opacity: 0.4;
    white-space: nowrap;
  }

  .sg-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.22rem 0.6rem;
  }

  .sg-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    cursor: default;
    padding: 0.06rem 0;
  }

  .sg-icon {
    width: 13px;
    height: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.55;
  }
  .sg-icon img {
    display: block;
    width: 11px;
    height: 11px;
  }

  .sg-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.25;
    flex-shrink: 0;
  }

  .sg-name {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    opacity: 0.45;
    white-space: nowrap;
    transition: opacity 0.12s;
  }

  .sg-item:hover .sg-name {
    opacity: 0.85;
  }
  .sg-item:hover .sg-icon {
    opacity: 0.9;
  }
</style>
