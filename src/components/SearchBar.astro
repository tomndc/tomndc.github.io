---
---

<div class="search-bar" id="search-bar" role="search">
  <label for="ps-input" class="sr-only">Search projects</label>

  <div class="input-shell" id="input-shell">
    <svg class="ico-search" viewBox="0 0 18 18" aria-hidden="true">
      <circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.35" fill="none"/>
      <path d="M11.5 11.5L16 16" stroke="currentColor" stroke-width="1.35" stroke-linecap="round"/>
    </svg>

    <div class="inline-hint" id="inline-hint" aria-hidden="true">
      <span class="ih-eg">Search by type or tech</span>
      <span class="ih-dot">—</span>
      <span class="ih-eg">e.g.</span>
      <span class="ih-pill type">Fullstack</span>
      <span class="ih-dot">·</span>
      <span class="ih-pill tech">Python</span>
      <span class="ih-dot">·</span>
      <span class="ih-pill type">featured</span>
    </div>

    <div class="chips-row" id="chips-row" role="group" aria-label="Active filters"></div>

    <input
      id="ps-input"
      type="text"
      placeholder=""
      autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
      aria-autocomplete="list" aria-controls="ps-sugs"
      aria-haspopup="listbox" aria-expanded="false"
    />

    <button id="ps-clear" class="ico-btn" aria-label="Clear all" type="button" hidden>
      <svg viewBox="0 0 14 14" aria-hidden="true">
        <path d="M11 3L3 11M3 3l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="back-row">
    <button class="back-btn" id="detail-back" aria-label="Back">
      <svg viewBox="0 0 14 14" aria-hidden="true">
        <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      back
    </button>
  </div>

  <ul id="ps-sugs" class="sugs" role="listbox" aria-label="Suggestions" hidden></ul>
</div>

<style>
  .search-bar { position: relative; }

  .input-shell {
    position: relative;
    display: flex; align-items: center; flex-wrap: wrap;
    gap: 0.3rem; border: 1px solid var(--border); border-radius: 3px;
    background: var(--surface); padding: 0.32rem 0.6rem;
    min-height: 34px; cursor: text;
    transition: border-color 0.16s, box-shadow 0.16s, background 0.16s;
  }
  .input-shell:focus-within {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: var(--surface-h);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .ico-search {
    width: 12px; height: 12px; flex-shrink: 0;
    opacity: 0.28; align-self: center; transition: opacity 0.16s;
    position: relative; z-index: 2;
  }
  .input-shell:focus-within .ico-search { opacity: 0.55; }

  .inline-hint {
    position: absolute; left: 30px; right: 36px; top: 50%;
    transform: translateY(-50%);
    display: flex; align-items: center; gap: 0.28rem;
    pointer-events: none; white-space: nowrap; overflow: hidden;
    z-index: 1; transition: opacity 0.15s;
  }
  .ih-eg   { font-size: 0.73rem; opacity: 0.32; }
  .ih-dot  { font-size: 0.65rem; opacity: 0.22; }
  .ih-pill {
    font-size: 0.59rem; padding: 0.05rem 0.3rem;
    border-radius: 999px; letter-spacing: 0.02em;
  }
  .ih-pill.tech { background: var(--lime-dim); color: var(--lime); border: 1px solid var(--lime-border); }
  .ih-pill.type { background: var(--accent-dim); color: var(--accent); border: 1px solid var(--accent-border); }

  .input-shell:focus-within .inline-hint,
  .input-shell.has-chips    .inline-hint,
  .input-shell.has-value    .inline-hint { opacity: 0; }

  :global(body[data-bio-state="featured"]) .inline-hint { opacity: 0; }

  .chips-row { display: contents; position: relative; z-index: 2; }

  #ps-input {
    flex: 1; min-width: 60px;
    background: transparent; border: none; outline: none;
    font-size: 0.815rem; color: inherit; font-family: inherit;
    caret-color: var(--accent); padding: 0;
    align-self: center; line-height: 1;
    position: relative; z-index: 2;
  }

  .ico-btn {
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px; flex-shrink: 0;
    background: var(--surface-h); border: none; border-radius: 50%;
    cursor: pointer; color: inherit; padding: 3.5px; align-self: center;
    transition: background 0.13s, opacity 0.13s;
    position: relative; z-index: 2;
  }
  .ico-btn[hidden] { display: flex !important; opacity: 0; pointer-events: none; }
  .ico-btn:hover   { background: var(--border); }
  .ico-btn svg     { width: 100%; height: 100%; }

  .back-row {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.2s ease;
  }
  :global(body.detail) .back-row { max-height: 2.5rem; }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    color: inherit;
    font: inherit;
    font-size: 0.67rem;
    opacity: 0.55;
    padding: 0.26rem 0.55rem;
    margin-top: 0.32rem;
    transition: opacity 0.15s, background 0.15s, border-color 0.15s;
  }
  .back-btn:hover { opacity: 1; background: var(--surface-h); border-color: var(--border-h); }
  .back-btn svg { width: 10px; height: 10px; }

  .sugs {
    position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    list-style: none; margin: 0; padding: 0.35rem;
    border-radius: 3px; border: 1px solid var(--border);
    background: var(--modal-bg);
    box-shadow: 0 12px 40px rgba(0,0,0,0.25);
    z-index: 200; opacity: 0; transform: translateY(-4px);
    transition: opacity 0.13s ease, transform 0.13s ease;
    pointer-events: none;
  }
  .sugs:not([hidden]) { opacity: 1; transform: translateY(0); pointer-events: all; }

  :global(.sug-item) {
    display: flex; align-items: center; gap: 0.45rem;
    padding: 0.3rem 0.5rem; border-radius: 2px;
    cursor: pointer; color: inherit;
    border: 1px solid transparent;
    transition: background 0.09s, border-color 0.09s;
    outline: none; user-select: none; background: none;
    font: inherit; font-size: 0.78rem;
  }
  :global(.sug-item:hover), :global(.sug-item.is-active) {
    background: var(--surface-h); border-color: var(--border);
  }
  :global(.sug-item img) { opacity: 0.75; flex-shrink: 0; }
</style>
